            "type": "string",
            "nullable": true
          },
          "timeoutMs": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "chunkIndex": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "FirmwareSizeBody": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "nullable": true
          },
          "timeoutMs": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "sizeBytes": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "HostBody": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "nullable": true
          },
          "timeoutMs": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VmcBroadcastBody": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "nullable": true
          },
          "groupId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "broadcastAddress": {
            "type": "string",
            "nullable": true
          },
          "port": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "localBind": {
            "type": "string",
            "nullable": true
          },
          "tokens": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "vmcItem": {
            "type": "string",
            "description": "Optional: B000|monitor (default) or B001|builtIn for SDCP item number in the VMC header.",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VmcGetBody": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "nullable": true
          },
          "field": {
            "type": "string",
            "nullable": true
          },
          "timeoutMs": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "sdcpUnitId": {
            "type": "integer",
            "format": "int32",
            "description": "Optional 0–255: SDCP single-connection unit (group 0). Omit for P2P (0,0).",
            "nullable": true
          },
          "vmcItem": {
            "type": "string",
            "description": "Optional: B000|monitor (default) or B001|builtIn.",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VmcSetBody": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "nullable": true
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "timeoutMs": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "sdcpUnitId": {
            "type": "integer",
            "format": "int32",
            "description": "Optional 0–255: SDCP single-connection unit (group 0). Omit for P2P (0,0).",
